# ── AI / Telephony ─────────────────────────────────────────────────────────
GEMINI_API_KEY=

# Model pins (smoke-tested at agent startup; scripted fallback if CU fails)
GEMINI_COMPUTER_USE_MODEL=gemini-3-flash-preview
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_REASONING_MODEL=gemini-2.0-flash

# Automation modes: gemini|scripted · browser|twilio|mock
COMPUTER_USE_MODE=gemini
VOICE_MODE=mock

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Phone number of the demo shipper the agent calls (E.164).
SHIPPER_PHONE_NUMBER=+867550000000

# ── Agent runtime ──────────────────────────────────────────────────────────
WEB_BASE_URL=http://localhost:3000
BROWSER_HEADLESS=true
# Demo: 30s wall-clock = 1 business day for sleep/wake
DEMO_TIME_COMPRESSION=30000

# ── Ports ──────────────────────────────────────────────────────────────────
WEB_PORT=3000
AGENT_PORT=8787

# ClearBorder V2 (FastAPI + sender app)
V2_BACKEND_PORT=8000
V2_FRONTEND_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
PORTAL_BASE_URL=http://localhost:8000/mock-customs

# Optional: override where the dashboard looks for the agent service.
# NEXT_PUBLIC_AGENT_PORT=8787
