# ── AI / Telephony ─────────────────────────────────────────────────────────
# Used by the live-call + agent workstreams. Not required to run the
# foundation demo (dashboard + portal + replayer work without them).
GEMINI_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Phone number of the demo shipper the agent calls (E.164).
# The seed script stamps this onto the "Shenzhen Bright Electronics" record.
SHIPPER_PHONE_NUMBER=+867550000000

# ── Ports ──────────────────────────────────────────────────────────────────
WEB_PORT=3000
AGENT_PORT=8787

# Optional: override where the dashboard looks for the agent service.
# Defaults to http://localhost:8787 (AGENT_PORT above).
# NEXT_PUBLIC_AGENT_PORT=8787
