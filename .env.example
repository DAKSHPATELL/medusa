# ClearBorder — environment configuration
# All secrets live in the server. The frontends never see the API key
# (browser voice, if enabled, uses short-lived ephemeral tokens only).
#
# Copy to `.env` in the repo root. With NO key set, the whole product runs
# in deterministic DEMO mode — no API calls, fully offline, safe for a video.

# ── Gemini ───────────────────────────────────────────────────────────────
# Leave blank to run the scripted demo. Set it to enable live mode.
GEMINI_API_KEY=

# Live-mode switches (both require GEMINI_API_KEY).
# DEMO_MODE=true  → scripted Live Translate call + scripted portal steps.
# DEMO_MODE=false + COMPUTER_USE_MODE=live → real Gemini Computer Use drives
#   the portal in a headless browser and streams frames into the office.
DEMO_MODE=true
COMPUTER_USE_MODE=

# Model pins (preview models — re-verify availability before a run).
CU_MODEL=gemini-2.5-computer-use-preview-10-2025
GEMINI_LIVE_TRANSLATE_MODEL=gemini-3.5-live-translate-preview

# ── Persistence (the Statement-Four backbone) ────────────────────────────
# local = SQLite that survives process restart (see server test suite).
CASE_STORE=local

# ── Ports ────────────────────────────────────────────────────────────────
PORT=3001                       # server: HTTP + WebSocket event bus
# Frontends (Vite): portal=5174 (Computer Use target), office=5175 (demo),
# console=5173 (operator). These are fixed in each app's vite.config.ts.

# ── Computer Use target ──────────────────────────────────────────────────
# The in-repo EU "Single Window" mock portal the agent drives.
PORTAL_URL=http://localhost:5174
CU_HEADLESS=true
