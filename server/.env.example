# server/.env.example
# ClearBorder API server configuration.
# All secrets stay in server/ — this file is never shipped to the console or portal.
# Copy to server/.env and fill in real values. Lines starting with # are comments.

# =====================================================================
# Core
# =====================================================================

# Google Gemini API key. Powers Live Translate and (in live mode) Computer Use.
# Leave BLANK to run fully in demo/simulated mode (no external calls, no key needed).
# NEVER commit a real key.
GEMINI_API_KEY=

# Case persistence backend. Only "local" is implemented (SQLite: clearborder.db).
CASE_STORE=local

# When "true", all AI paths use canned/simulated responses (no Gemini calls).
# Also auto-enabled whenever GEMINI_API_KEY is empty.
DEMO_MODE=true

# HTTP/WebSocket port the Fastify server listens on.
PORT=3001

# =====================================================================
# Computer Use
# =====================================================================

# Correction engine mode:
#   (unset/anything) = simulated demo path (no browser, no key required)
#   "live"           = drive the real portal with Playwright + Gemini Computer Use
#                      (only takes effect if GEMINI_API_KEY is also set)
COMPUTER_USE_MODE=

# Gemini Computer Use model id used in live mode.
CU_MODEL=gemini-2.5-computer-use-preview-10-2025

# Run the Playwright browser headless. Set to "false" to watch it on screen.
CU_HEADLESS=true

# Safety cap on agent turns per live correction run.
CU_MAX_TURNS=30

# =====================================================================
# Live portal target (only used when COMPUTER_USE_MODE=live)
# =====================================================================
# Defaults below point at the public TÉLÉDEC customs-broker mockup site.
# Override PORTAL_URL to http://localhost:5174 to drive the local portal instead.

# Login URL of the customs-broker portal. Its origin is reused for the URLs below.
PORTAL_URL=https://www.douanneportalmockup.com/courtier/login

# Broker login credentials (pre-filled demo/public creds for the mockup site).
CU_EORI=FR12345678900042
CU_PASSWORD=teledec-2026

# Flagged dossier (file) the agent opens — on "HOLD DOUANIER — Écart de valeur".
CU_DOSSIER=CLR-2026-0042

# "Valeur en douane" tab URL. Defaults to <origin>/courtier/dossier/<CU_DOSSIER>?tab=valeur.
CU_VALEUR_URL=

# Corrected declared value the agent types in — matches the invoiced value.
CU_TARGET_VALUE=14500.00

# The original "wrong" declared value used to reset the field before correcting.
CU_RESET_VALUE=12000.00

# CSS selector of the final "SOUMETTRE LA MODIFICATION" button. The agent is
# gated to NEVER click this; submit only happens on explicit human /confirm.
CU_SUBMIT_SELECTOR=#btn-soumettre

# Justification text written alongside the corrected value.
CU_JUSTIFICATION=Valeur déclarée alignée sur la valeur facturée CIF (fret international inclus dans la facture). Écart résolu conformément à la valeur transactionnelle.
